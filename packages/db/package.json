{
  "name": "@pixeleye/db",
  "version": "0.1.0",
  "dependencies": {
    "@prisma/client": "4.9.0"
  },
  "devDependencies": {
    "dotenv-cli": "7.0.0",
    "prisma": "4.9.0",
    "typescript": "4.9.4"
  },
  "license": "MIT",
  "main": "./index.ts",
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "db:generate": "pnpm with-env prisma generate",
    "db:push": "pnpm with-env prisma db push --skip-generate",
    "dev": "pnpm with-env prisma studio --port 5556",
    "with-env": "dotenv -e ../../.env --"
  },
  "types": "./index.ts"
}
