// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model SnapImage {
    id        String @id @default(cuid())
    hash      String
    projectId String
    url       String @unique

    project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
    ImageSnapshot ImageSnapshot[]

    @@unique([projectId, hash])
}

model DiffImage {
    id   String  @id @default(cuid())
    hash String  @unique
    url  String? @unique
}

enum BrowserEnum {
    UNKNOWN
    CHROME
    FIREFOX
    SAFARI
    EDGE
}

model ImageSnapshot {
    id        String      @id @default(cuid())
    browser   BrowserEnum @default(UNKNOWN)
    viewport  String      @default("")
    imageId   String
    projectId String

    image      SnapImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
    project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    Snapshot   Snapshot? @relation(fields: [snapshotId], references: [id])
    snapshotId String?

    @@unique([imageId, browser, viewport])
}

model Snapshot {
    id             String          @id @default(cuid())
    sha            String
    name           String
    variant        String
    projectId      String
    imageSnapshots ImageSnapshot[]

    project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    report      Report?    @relation(fields: [reportSha, reportProjectId], references: [sha, projectId])
    baseline    Snapshot?  @relation("BaselineSnapshot", fields: [baselineId], references: [id])
    baselineFor Snapshot[] @relation("BaselineSnapshot")

    reportSha       String?
    reportProjectId String?
    baselineId      String?

    @@unique([sha, name, variant])
}

model Report {
    sha       String
    projectId String
    createdAt DateTime   @default(now())
    snapshots Snapshot[]

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    Build   Build[]

    @@id([sha, projectId])
}

model BuildCounts {
    projectId String @id
    count     Int    @default(0)

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum BuildStatus {
    ORPHANED
    PENDING
    COMPLETED
    FAILED
    UNREVIEWED
}

model Build {
    id        String      @id @default(nanoid())
    projectId String
    branch    String
    sha       String
    name      String
    message   String? // e.g. commit message
    title     String? // e.g. pull request title
    url       String? // e.g. pull request url
    base      Boolean     @default(false)
    createdAt DateTime    @default(now())
    status    BuildStatus

    parent  Build[] @relation("BuildHistory")
    child   Build[] @relation("BuildHistory")
    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    report  Report  @relation(fields: [sha, projectId], references: [sha, projectId])

    @@unique([projectId, sha])
}

enum TeamType {
    GITHUB
    GITLAB
    BITBUCKET
    USER
}

model Team {
    id   String   @id @default(cuid())
    name String
    type TeamType

    users    UserOnTeam[]
    projects Project[]
    Source   Source[]
    image    String?
}

enum TeamRole {
    OWNER
    ADMIN
    MEMBER
}

model UserOnTeam {
    team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId String
    user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String
    role   TeamRole

    @@id([teamId, userId])
}

enum SourceEnum {
    GITHUB
    GITLAB
    BITBUCKET
    OTHER
}

model Source {
    id              String     @id @default(cuid())
    type            SourceEnum
    githubInstallId String?    @unique
    gitId           String     @unique
    // Either one of these is populated depending on if it's a user space or team space
    Team            Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId          String?
    Project         Project[]

    @@unique([type, teamId])
}

model Project {
    id       String  @id @default(nanoid())
    gitId    String
    name     String
    key      String  @unique @default(cuid())
    secret   String
    url      String?
    teamId   String?
    sourceId String

    users  UserOnProject[]
    Team   Team?           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    source Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)

    builds        Build[]
    SnapImage     SnapImage[]
    ImageSnapshot ImageSnapshot[]
    Snapshot      Snapshot[]
    Report        Report[]
    BuildCounts   BuildCounts[]
}

enum UserOnProjectType {
    ADMIN
    CONTRIBUTOR
    EXTERNAL
}

enum ProjectRole {
    OWNER
    REVIEWER
    VIEWER
}

model UserOnProject {
    project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String
    user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    role      ProjectRole
    type      UserOnProjectType

    @@id([projectId, userId])
}

// @see https://next-auth.js.org/schemas/models
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? @db.Text
    refresh_token_expires_in Int?
    access_token             String? @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String          @id @default(cuid())
    name          String?
    email         String?         @unique
    emailVerified DateTime?
    nickName      String?
    image         String?
    accounts      Account[]
    sessions      Session[]
    UserOnTeam    UserOnTeam[]
    UserOnProject UserOnProject[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
