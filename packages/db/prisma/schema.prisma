// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum ProjectRole {
    OWNER
    REVIEWER
    VIEWER
}

enum TeamRole {
    OWNER
    ADMIN
    MEMBER
}

enum SourceEnum {
    GITHUB
    GITLAB
    BITBUCKET
    OTHER
}

enum TeamType {
    GITHUB
    GITLAB
    BITBUCKET
    USER
}

model Image {
    id                    String             @id @default(cuid())
    hash                  String             @unique
    createdAt             DateTime           @default(now())
    baseVisualDifferences VisualDifference[] @relation("baseImage")
    visualDiffernces      VisualDifference[] @relation("image")
    visualSnapshots       VisualSnapshot[]
}

enum VisualDifferenceStatus {
    PENDING
    COMPLETED
    FAILED
}

enum VisualDifferenceError {
    BASE_IMAGE_NOT_FOUND
    IMAGE_NOT_FOUND
}

model VisualDifference {
    id          String                  @id @default(cuid())
    baseImage   Image                   @relation("baseImage", fields: [baseImageId], references: [id], onDelete: Cascade)
    baseImageId String
    image       Image                   @relation("image", fields: [imageId], references: [id], onDelete: Cascade)
    imageId     String
    status      VisualDifferenceStatus
    errorr      VisualDifferenceError[]

    createdAt      DateTime         @default(now())
    visualSnapshot VisualSnapshot[]
}

model VisualSnapshot {
    id                 String           @id @default(cuid())
    builds             Build[]
    image              Image?           @relation(fields: [imageId], references: [id])
    imageId            String?
    visualDifferences  VisualDifference @relation(fields: [visualDifferenceId], references: [id], onDelete: Cascade)
    createdAt          DateTime         @default(now())
    visualDifferenceId String
}

model DomSnapshot {
    id        String   @id @default(cuid())
    builds    Build[]
    createdAt DateTime @default(now())
}

model Build {
    id               String           @id @default(cuid())
    sha              String
    Project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId        String
    visualSnapshots  VisualSnapshot[]
    domSnapshots     DomSnapshot[]
    commitMessage    String?
    pullRequestTitle String?
    url              String?
    createdAt        DateTime         @default(now())

    @@unique([projectId, sha])
}

model Team {
    id       String       @id @default(cuid())
    name     String
    type     TeamType
    users    UserOnTeam[]
    projects Project[]
    Source   Source[]
}

model UserOnTeam {
    team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId String
    user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String
    role   TeamRole

    @@id([teamId, userId])
}

model Source {
    id              String     @id @default(cuid())
    type            SourceEnum
    githubInstallId Int?       @unique
    // Either one of these is populated depending on if it's a user space or team space
    Team            Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId          String?
    User            User?      @relation(fields: [userId], references: [id])
    userId          String?
    Project         Project[]
}

model Project {
    id       String          @id @default(cuid())
    gitId    String
    name     String
    key      String          @unique @default(cuid())
    secret   String
    url      String?
    source   Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
    sourceId String
    builds   Build[]
    users    UserOnProject[]
    Team     Team?           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId   String?
}

model UserOnProject {
    project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectId String
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    role      ProjectRole

    @@id([projectId, userId])
}

// @see https://next-auth.js.org/schemas/models
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? @db.Text
    refresh_token_expires_in Int?
    access_token             String? @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String          @id @default(cuid())
    name          String?
    email         String?         @unique
    emailVerified DateTime?
    nickName      String?
    image         String?
    accounts      Account[]
    sessions      Session[]
    UserOnTeam    UserOnTeam[]
    sources       Source[]
    UserOnProject UserOnProject[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
