    "@storybook/blocks": "7.0.0-beta.36",
    "@storybook/react": "7.0.0-beta.36",
    "@storybook/react-webpack5": "7.0.0-beta.36",
    "@storybook/testing-library": "0.0.13",
    "@types/react": "18.0.27",
    "@types/react-dom": "18.0.10",
