{
  "name": "@pixeleye/ui",
  "version": "0.0.0",
  "main": "./index.tsx",
  "types": "./index.tsx",
  "license": "MIT",
  "scripts": {
    "lint": "TIMING=1 eslint \"**/*.ts*\"",
    "storybook": "concurrently \"pnpm:watch:*\"",
    "build-storybook": "concurrently \"pnpm:build:*\"",
    "build:css": "npx tailwindcss -i ./styles/tailwind.css -o ./public/tailwind.css",
    "build:storybook": "storybook build",
    "watch:css": "npx tailwindcss -i ./styles/tailwind.css -o ./public/tailwind.css --watch",
    "watch:storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@pixeleye/tailwind-config": "*",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@storybook/addon-essentials": "7.0.0-beta.36",
    "@storybook/addon-interactions": "7.0.0-beta.36",
    "@storybook/addon-links": "7.0.0-beta.36",
    "@storybook/blocks": "7.0.0-beta.36",
    "@storybook/react": "7.0.0-beta.36",
    "@storybook/react-webpack5": "7.0.0-beta.36",
    "@storybook/testing-library": "0.0.13",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "concurrently": "^7.6.0",
    "eslint": "^8.32.0",
    "prop-types": "15.8.1",
    "react": "^18.2.0",
    "react-dom": "18.2.0",
    "storybook": "7.0.0-beta.36",
    "typescript": "^4.9.4",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.4",
    "autoprefixer": "^10.4.13"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.1",
    "class-variance-authority": "^0.4.0"
  }
