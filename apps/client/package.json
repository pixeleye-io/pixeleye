{
  "name": "@pixeleye/client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm with-env next build",
    "dev": "concurrently \"pnpm:dev:*\"",
    "clean": "rm -rf .next .turbo node_modules",
    "dev:start": "pnpm with-env next dev -p 3000",
    "dev:forward": "pnpm smee -u https://smee.io/No0KVHCmvP2CmoZ --port 3000 --path /api/webhooks/github",
    "lint": "SKIP_ENV_VALIDATION=1 next lint",
    "type-check": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.14",
    "@pixeleye/api": "*",
    "@pixeleye/auth": "*",
    "@pixeleye/db": "*",
    "@pixeleye/github": "*",
    "@pixeleye/hooks": "*",
    "@pixeleye/tailwind-config": "*",
    "@pixeleye/ui": "*",
    "@pixeleye/utils": "*",
    "@radix-ui/react-avatar": "^1.0.1",
    "@radix-ui/react-dialog": "^1.0.2",
    "@radix-ui/react-dropdown-menu": "^2.0.2",
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-select": "^1.2.0",
    "@tanstack/react-query": "4.23.0",
    "@trpc/client": "10.9.0",
    "@trpc/next": "10.9.0",
    "@trpc/react-query": "10.9.0",
    "@trpc/server": "10.9.0",
    "class-variance-authority": "0.4.0",
    "framer-motion": "8.5.5",
    "next": "13.1.6",
    "next-auth": "4.19.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^3.20.2",
    "zustand": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "18.0.0",
    "@types/react": "18.0.27",
    "@types/react-dom": "18.0.10",
    "autoprefixer": "10.4.13",
    "concurrently": "7.6.0",
    "dotenv-cli": "7.0.0",
    "eslint": "8.32.0",
    "eslint-config-next": "13.1.6",
    "postcss": "8.4.21",
    "tailwindcss": "3.2.4",
    "typescript": "4.9.4"
  }
}
